{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/soap-calc/soap-calc/schemas/oils.schema.json",
    "title": "Oil Database",
    "description": "Schema for the oils database (data/oils.json).",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "name",
            "sap_koh",
            "sap_naoh",
            "fatty_acids"
        ],
        "properties": {
            "name": {
                "type": "string",
                "description": "Unique name of the oil (case-insensitive)."
            },
            "sap_koh": {
                "type": "number",
                "description": "Saponification value for KOH (Potassium Hydroxide)."
            },
            "sap_naoh": {
                "type": "number",
                "description": "Saponification value for NaOH (Sodium Hydroxide)."
            },
            "iodine": {
                "type": "number",
                "description": "Average Iodine Value.",
                "default": 0.0
            },
            "ins": {
                "type": "number",
                "description": "INS Value (Iodine - SAP).",
                "default": 0.0
            },
            "fatty_acids": {
                "type": "object",
                "description": "Fatty acid profile percentages (should sum to approx 100).",
                "properties": {
                    "lauric": {
                        "type": "number",
                        "default": 0.0
                    },
                    "myristic": {
                        "type": "number",
                        "default": 0.0
                    },
                    "palmitic": {
                        "type": "number",
                        "default": 0.0
                    },
                    "stearic": {
                        "type": "number",
                        "default": 0.0
                    },
                    "ricinoleic": {
                        "type": "number",
                        "default": 0.0
                    },
                    "oleic": {
                        "type": "number",
                        "default": 0.0
                    },
                    "linoleic": {
                        "type": "number",
                        "default": 0.0
                    },
                    "linolenic": {
                        "type": "number",
                        "default": 0.0
                    }
                },
                "additionalProperties": false
            },
            "notes": {
                "type": "string",
                "description": "Optional notes or source information."
            }
        },
        "additionalProperties": false
    }
}