{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/soap-calc/soap-calc/schemas/additives.schema.json",
    "title": "Additive Database",
    "description": "Schema for the additives database (data/additives.json).",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "name",
            "category",
            "usage",
            "stage",
            "purpose"
        ],
        "properties": {
            "name": {
                "type": "string",
                "description": "Name of the additive."
            },
            "category": {
                "type": "string",
                "description": "Category (e.g., colorant, exfoliant, hardener)."
            },
            "usage": {
                "type": "object",
                "required": [
                    "min",
                    "max",
                    "unit",
                    "per"
                ],
                "properties": {
                    "min": {
                        "type": "number",
                        "description": "Minimum recommended usage rate."
                    },
                    "max": {
                        "type": "number",
                        "description": "Maximum recommended usage rate."
                    },
                    "unit": {
                        "type": "string",
                        "enum": [
                            "tsp",
                            "tbsp",
                            "pct",
                            "pinch",
                            "g",
                            "oz"
                        ],
                        "description": "Unit of measurement (pct = percentage)."
                    },
                    "per": {
                        "type": "string",
                        "enum": [
                            "lb_oils",
                            "oil_weight",
                            "liquid_weight",
                            "batch_weight"
                        ],
                        "description": "Basis for usage calculation."
                    }
                },
                "additionalProperties": false
            },
            "stage": {
                "type": "string",
                "description": "Recommended stage to add (e.g. trace, lye, pre_cook, post_cook)."
            },
            "purpose": {
                "type": "string",
                "description": "Description of effect."
            },
            "notes": {
                "type": "string",
                "description": "Handling notes or warnings."
            }
        },
        "additionalProperties": false
    }
}