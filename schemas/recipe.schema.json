{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/soap-calc/soap-calc/schemas/recipe.schema.json",
    "title": "Soap Recipe",
    "description": "Input format for soap recipes (JSON/YAML).",
    "type": "object",
    "required": [
        "name",
        "oils"
    ],
    "properties": {
        "name": {
            "type": "string",
            "description": "Recipe name."
        },
        "lye_type": {
            "type": "string",
            "enum": [
                "NaOH",
                "KOH",
                "Hybrid (Dual Lye)"
            ],
            "default": "NaOH",
            "description": "Primary lye type."
        },
        "naoh_ratio": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "default": 100,
            "description": "If Hybrid, percentage of NaOH (0-100). Rest is KOH."
        },
        "superfat_pct": {
            "type": "number",
            "minimum": 0,
            "default": 5.0,
            "description": "Lye discount percentage (standard) or superfat if separate superfat_oils used."
        },
        "water_mode": {
            "type": "string",
            "enum": [
                "Water:Lye Ratio",
                "Lye Concentration",
                "Water as % of Oils"
            ],
            "default": "Water:Lye Ratio",
            "description": "Method for calculating water amount."
        },
        "water_value": {
            "type": "number",
            "minimum": 0,
            "default": 2.0,
            "description": "Value corresponding to the water_mode (e.g., 2.0 for 2:1 ratio)."
        },
        "liquid_discount_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "default": 0.0,
            "description": "Additional liquid discount percentage (applied after calculation)."
        },
        "default_oil_weight": {
            "type": "number",
            "minimum": 0,
            "default": 800.0,
            "description": "Default total oil weight in grams if no mold specified."
        },
        "ignore_warnings": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of validation warning codes to suppress."
        },
        "notes": {
            "type": "string",
            "description": "Recipe notes."
        },
        "mold": {
            "type": "object",
            "description": "Mold dimensions for auto-sizing the batch.",
            "required": [
                "length",
                "width",
                "height"
            ],
            "properties": {
                "length": {
                    "type": "number"
                },
                "width": {
                    "type": "number"
                },
                "height": {
                    "type": "number"
                },
                "fill_factor": {
                    "type": "number",
                    "default": 0.95
                }
            },
            "additionalProperties": false
        },
        "oils": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "oil",
                    "percentage"
                ],
                "properties": {
                    "oil": {
                        "type": "string",
                        "description": "Name of the oil (must match database)."
                    },
                    "percentage": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                    }
                }
            }
        },
        "liquids": {
            "type": "array",
            "description": "Liquid ingredients (e.g. water, milk, aloe). Defaults to 100% Water.",
            "items": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "percentage": {
                        "type": "number",
                        "default": 100.0,
                        "description": "% of total liquid weight"
                    },
                    "handling_notes": {
                        "type": "string"
                    }
                }
            }
        },
        "additives": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "amount": {
                        "type": "number",
                        "description": "Absolute amount in grams (overrides percentage)."
                    },
                    "percentage": {
                        "type": "number",
                        "description": "Usage rate %."
                    },
                    "percent_base": {
                        "type": "string",
                        "enum": [
                            "Oil Weight",
                            "Liquid Weight",
                            "Total Batch Weight"
                        ],
                        "default": "Oil Weight"
                    },
                    "stage": {
                        "type": "string",
                        "default": "Light Trace"
                    },
                    "notes": {
                        "type": "string"
                    }
                }
            }
        },
        "fragrances": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "Fragrance Oil",
                            "Essential Oil"
                        ],
                        "default": "Fragrance Oil"
                    },
                    "amount": {
                        "type": "number"
                    },
                    "percentage": {
                        "type": "number"
                    },
                    "max_safe_pct": {
                        "type": "number",
                        "description": "IFRA safety limit %."
                    },
                    "stage": {
                        "type": "string",
                        "default": "Light Trace"
                    },
                    "notes": {
                        "type": "string"
                    }
                }
            }
        },
        "superfat_oils": {
            "type": "array",
            "description": "Oils added After Cook / Post-Trace (Hot Process or specialized).",
            "items": {
                "type": "object",
                "required": [
                    "oil",
                    "percentage"
                ],
                "properties": {
                    "oil": {
                        "type": "string"
                    },
                    "percentage": {
                        "type": "number",
                        "description": "% of the Superfat Phase (components of the post-cook oil blend)."
                    }
                }
            }
        }
    },
    "additionalProperties": false
}